# Add ARM64 MSVC target block to NSS's gyp configuration.
#
# NSS's config.gypi has per-arch MSVS settings for ia32 and x64 but not ARM64.
# Without this block, gyp leaves msvs_configuration_platform unset for ARM64
# (defaults to x86), causing ninja to use the wrong environment and tool paths.
#
# gyp-next >= 0.22.0 handles ARM64 toolchain discovery (environment.arm64,
# armasm64.exe), but NSS still needs its own preprocessor definitions here.
#
# Removable once NSS adds an ARM64 block to coreconf/config.gypi upstream.
--- a/nss/coreconf/config.gypi
+++ b/nss/coreconf/config.gypi
@@ -589,6 +589,19 @@
                   },
                 },
               }],
+              [ 'target_arch=="arm64"', {
+                'msvs_configuration_platform': 'ARM64',
+                'msvs_settings': {
+                  'VCCLCompilerTool': {
+                    'PreprocessorDefinitions': [
+                      'WIN64',
+                      '_ARM64_',
+                      '__ARM_FEATURE_CRYPTO',
+                    ],
+                    'AdditionalOptions': [ '/EHsc' ],
+                  },
+                },
+              }],
             ],
           }],
           [ 'disable_dbm==1', {
